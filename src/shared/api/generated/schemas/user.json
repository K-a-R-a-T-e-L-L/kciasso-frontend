{
  "type": "object",
  "properties": {
    "id": { "type": "integer", "format": "int32" },
    "name": { "type": "string" },
    "email": { "type": "string" },
    "password": { "type": "string" },
    "is_super_admin": { "type": "boolean" },
    "is_active": { "type": "boolean" },
    "can_manage_site_settings": { "type": "boolean" },
    "can_manage_news": { "type": "boolean" },
    "documents_access_mode": {
      "type": "string",
      "enum": ["NONE", "ALL", "SELECTED_GROUPS"]
    },
    "document_groups": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["GIA_9", "GIA_11", "GIA", "QUALITY", "REGIONAL", "ABOUT"]
      }
    },
    "sessions": {
      "type": "array",
      "items": { "$ref": "#/components/schemas/Session" }
    },
    "section_permissions": {
      "type": "array",
      "items": { "$ref": "#/components/schemas/UserSectionPermission" }
    },
    "authored_news": {
      "type": "array",
      "items": { "$ref": "#/components/schemas/News" }
    },
    "created_documents": {
      "type": "array",
      "items": { "$ref": "#/components/schemas/Document" }
    },
    "updated_documents": {
      "type": "array",
      "items": { "$ref": "#/components/schemas/Document" }
    },
    "created_document_versions": {
      "type": "array",
      "items": { "$ref": "#/components/schemas/DocumentVersion" }
    },
    "created_document_share_links": {
      "type": "array",
      "items": { "$ref": "#/components/schemas/DocumentShareLink" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": "string", "format": "date-time", "nullable": true }
  },
  "required": [
    "id",
    "name",
    "email",
    "password",
    "is_super_admin",
    "is_active",
    "can_manage_site_settings",
    "can_manage_news",
    "documents_access_mode",
    "document_groups",
    "created_at",
    "updated_at",
    "deleted_at"
  ],
  "x-readme-ref-name": "User"
}
